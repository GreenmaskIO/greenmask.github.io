{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server (make start)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "make",
      "runtimeArgs": ["start"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "(?:Local:|Docusaurus website is running at:?)\\s+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    }
  ]
}
